      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
