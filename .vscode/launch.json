      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homework_06/ballistics_check",
      "args": [
        "${workspaceFolder}/homework_06/data/${input:fileSelectHW6}"
      // Локальний debug стартера ДЗ 5. preLaunchTask збирає debug preset.
      "name": "Debug homework_05: telemetry_check",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homework_05/telemetry_check",
      "args": [
        "table"
