{
  // Launch configurations працюють у devcontainer і використовують GDB з image.
  // Для ДЗ 5 потрібно буде додати окрему конфігурацію за цим прикладом.
  "version": "0.2.0",
  "configurations": [
    {
      // Локальний debug demo-коду заняття 2.4. Використовує bad input,
      // щоб GDB зупинився на runtime crash.
      "name": "Debug demo 2.4: debug_probe",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/demos/lesson_2_4/debug_probe/debug_probe",
      "args": [
        "${workspaceFolder}/demos/lesson_2_4/debug_probe/data/bad_missing_field.txt"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      // Локальний debug стартера ДЗ 4. preLaunchTask збирає debug preset.
      "name": "Debug homework_04: ugv_odometry",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homework_04/ugv_odometry",
      "args": [
        "${workspaceFolder}/homework_04/data/straight.txt"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      // Локальний debug стартера ДЗ 4. preLaunchTask збирає debug preset.
      "name": "Debug homework_07: ballistics",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/drone_ballistics/ballistics",
      // "args": [
      //   "${workspaceFolder}/drone_ballistics/data/straight.txt"
      // ],
      // Локальний debug стартера ДЗ 5. preLaunchTask збирає debug preset.
      "name": "Debug homework_05: telemetry_check",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homework_05/telemetry_check",
      "args": [
        "${workspaceFolder}/homework_05/data/${input:telemetryFile}"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "telemetryFile",
      "type": "pickString",
      "description": "Which telemetry file to debug?",
      "options": [
        "good.txt",
        "bad_missing_field.txt",
        "bad_invalid_number.txt",
        "bad_zero_delta.txt",
        "empty.txt"
      ],
      "default": "good.txt"
    }
  ]
}